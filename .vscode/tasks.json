{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure HelloQt",
      "type": "shell",
      "command": "/opt/homebrew/bin/cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build",
        "-G",
        "Ninja",
        "-DCMAKE_PREFIX_PATH=/Users/sxr/Qt/6.11.0/macos",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build HelloQt",
      "type": "shell",
      "command": "/opt/homebrew/bin/cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build"
      ],
      "dependsOn": "Configure HelloQt",
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}